# AirTrack Lite — Environment Configuration
# Copy this file to .env before running AirTrack.
# The installer does this automatically.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=airtrack-db
DB_NAME=airtrack
DB_USER=airtrack_user
DB_PASSWORD=airtrack_pass

# ── Flask ─────────────────────────────────────────────────────────────────────
# Change SECRET_KEY to a random string for production use.
SECRET_KEY=change-me-to-something-random

# ── Timezone ──────────────────────────────────────────────────────────────────
# Set your local timezone. Examples:
#   Australia/Sydney   Europe/London   America/New_York   Asia/Singapore
TZ=UTC
